datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  name        String?
  devicePin   String?  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  alerts      Alert[]
  holdings    Holding[]
}

model OtpVerification {
  id        String   @id @default(uuid())
  email     String   @unique
  code      String   // The 6-digit verification code
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Alert {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticker      String
  targetPrice Float
  direction   String   // "ABOVE" or "BELOW"
  isTriggered Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Asset {
  id        String   @id @default(uuid())
  symbol    String   @unique
  name      String
  type      String   // e.g., "US", "Domestic", "Forex", "ETF"
  category  String   // e.g., "Stock", "Currency", "Fund"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Holding {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticker    String
  name      String
  shares    Float
  avgCost   Float
  marketId  String   // "domestic", "us", "other", "crypto", "metals"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}